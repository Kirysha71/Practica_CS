<Window x:Class="ElectronicJournal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронный журнал" Height="600" Width="800"
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15" 
                                BorderThickness="0"
                                Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Электронный журнал" 
                       FontSize="28" FontWeight="Bold" 
                       Foreground="#2196F3" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Предмет: " VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                <ComboBox x:Name="cmbSubjects" Width="250" Height="30" FontSize="14">
                    <ComboBoxItem Content="Математика"/>
                    <ComboBoxItem Content="Физика"/>
                    <ComboBoxItem Content="Информатика"/>
                    <ComboBoxItem Content="Русский язык"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dgJournal" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="True"
                  Background="White"
                  BorderBrush="#DDDDDD"
                  HeadersVisibility="Column"
                  RowHeight="35"
                  Margin="0,0,0,20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО студента" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Оценка" Binding="{Binding Grade}" Width="100"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button Content="Добавить оценку" 
                    Click="BtnAddGrade_Click"
                    Width="150" Height="35" 
                    Background="#2196F3" 
                    Foreground="White"
                    FontSize="14"
                    Margin="0,0,10,0"/>

            <Button Content="Сохранить" 
                    Click="BtnSave_Click"
                    Width="120" Height="35" 
                    Background="#FFA000FF" 
                    Foreground="White"
                    FontSize="14"/>
        </StackPanel>
    </Grid>
</Window>